#!/usr/bin/env bash
# molt — My Opinionated Local Terminal
# Thin coordinator: parse args, delegate to lib functions.

set -euo pipefail

# Resolve symlinks so MOLT_ROOT works when invoked via ~/bin/molt symlink
_molt_self="${BASH_SOURCE[0]}"
while [[ -L "$_molt_self" ]]; do
  _molt_self="$(readlink "$_molt_self")"
done
MOLT_ROOT="$(cd "$(dirname "$_molt_self")/.." && pwd)"
unset _molt_self

# Source core libraries
# shellcheck source=../lib/molt.sh
source "${MOLT_ROOT}/lib/molt.sh"
# shellcheck source=../lib/liberator.sh
source "${MOLT_ROOT}/lib/liberator.sh"

# --- Commands ---

cmd_help() {
  cat <<EOF
${MOLT_NAME} v${MOLT_VERSION} — My Opinionated Local Terminal
Your shell config is your identity. Every new machine is just a new body.

Usage: molt <command> [args]

Commands:
  resleeve [--dry-run]  Bootstrap the current machine from your stack
  upgrade [--dry-run] [liberators] [--resleeve|--no-resleeve]
                        Pull latest, run upgrade hooks, then resleeve
                        With liberators: upgrade only those (comma-separated)
                        Default: resleeve after full upgrade, no resleeve after targeted
  status      Show current sleeve state and liberator status
  list        List liberators with enabled/disabled/installed status
  doctor      System diagnostics and health checks
  test        Run bats test suite (molt test [liberator])
  version     Show version
  help        Show this help message

EOF
}

cmd_status() {
  echo "${MOLT_NAME} v${MOLT_VERSION}"
  echo ""
  echo "Sleeve: $(hostname -s 2>/dev/null || hostname)"
  echo "Platform: $(molt_platform)"
  echo "Distro: $(molt_distro)"
  echo "Arch: $(molt_arch)"
  echo ""

  local user_repo
  user_repo="$(molt_find_user_repo 2>/dev/null || echo "")"
  if [[ -n "$user_repo" ]]; then
    echo "Stack: $user_repo"
  else
    echo "Stack: not found"
  fi

  echo ""
  echo "Liberators:"
  liberator_status_all $(liberator_list)
}

cmd_resleeve() {
  local dry_run=false
  if [[ "${1:-}" == "--dry-run" ]]; then
    dry_run=true
  fi

  if $dry_run; then
    echo "${MOLT_NAME} v${MOLT_VERSION} — Dry Run"
  else
    echo "${MOLT_NAME} v${MOLT_VERSION} — My Opinionated Local Terminal"
    echo "Needlecasting stack to new sleeve..."
  fi
  echo "Sleeve: $(hostname -s 2>/dev/null || hostname) | Platform: $(molt_platform)"
  echo ""

  local user_repo
  user_repo="$(molt_find_user_repo)" || {
    molt_error "Cannot resleeve without a user config repo."
    exit 1
  }

  molt_info "Stack found: $user_repo"
  molt_info "Loading liberators..."

  # Use manifest if available, otherwise fall back to directory scan
  local liberators
  if liberators="$(molt_enabled_liberators 2>/dev/null)" && [[ -n "$liberators" ]]; then
    local manifest
    manifest="$(molt_find_manifest)"
    molt_info "Manifest: $manifest"
  else
    liberators="$(liberator_list)"
    molt_info "No manifest found, using all available liberators"
  fi

  local would_install=0
  local failed=0
  echo ""

  while IFS= read -r lib; do
    [[ -z "$lib" ]] && continue
    if ! liberator_load "$lib" 2>/dev/null; then
      molt_warn "Skipping unknown liberator: $lib"
      continue
    fi
    if ! liberator_check "$lib" 2>/dev/null; then
      if $dry_run; then
        echo "  $lib: WOULD INSTALL"
        would_install=$((would_install + 1))
      else
        if liberator_run "$lib" install; then
          echo "  $lib: ✓ installed"
        else
          molt_error "Liberator failed: $lib — continuing with remaining liberators"
          ((failed++))
        fi
      fi
    else
      echo "  $lib: ✓ ok"
    fi
  done <<< "$liberators"

  echo ""
  if $dry_run; then
    if [[ $would_install -eq 0 ]]; then
      molt_info "All liberators are installed. Nothing to do."
    else
      molt_info "$would_install liberator(s) would be installed. Run \`molt resleeve\` to apply."
    fi
  else
    if [[ $failed -gt 0 ]]; then
      molt_error "$failed liberator(s) failed. Review errors above."
    else
      molt_info "Sleeve ready. Welcome back."
    fi
  fi
}

# --- Main ---

case "${1:-help}" in
  resleeve) shift; cmd_resleeve "$@" ;;
  upgrade)  shift; cmd_upgrade "$@" ;;
  status)   cmd_status ;;
  list)     cmd_list ;;
  doctor)   cmd_doctor ;;
  test)     shift; cmd_test "$@" ;;
  version)  cmd_version ;;
  help)     cmd_help ;;
  *)
    molt_error "Unknown command: $1"
    cmd_help
    exit 1
    ;;
esac
