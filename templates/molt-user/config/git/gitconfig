[user]
	name = __MOLT_FULL_NAME__
	email = __MOLT_EMAIL__
[core]
	excludesfile = ~/.gitignore_global
	autocrlf = false
[init]
	defaultBranch = main
[pull]
	rebase = true
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[http]
	sslVerify = true
[include]
	path = ~/.gitconfig___MOLT_GITHUB__
